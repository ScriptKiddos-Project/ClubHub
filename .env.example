# Server
NODE_ENV=development
PORT=5000

# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://username:password@host:port/clubhub?schema=public"

# Redis (Railway Redis)
REDIS_URL="redis://default:password@host:port"

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourclub.edu
EMAIL_FROM_NAME=ClubHub

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173

# HMAC secret for QR codes
QR_HMAC_SECRET=your_qr_hmac_secret_min_32_chars

# Cloudinary (optional for Phase 1)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret